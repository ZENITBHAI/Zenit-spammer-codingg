local tabs = {}
local tabButtons = {}

local function createTab(name, posIndex, totalTabs)
    local widthShare = 1 / totalTabs
    local btn = Instance.new("TextButton")
    btn.Size = UDim2.new(widthShare - 0.01, 0, 1, 0)
    btn.Position = UDim2.new((posIndex - 1) * widthShare, 0, 0, 0)
    btn.BackgroundTransparency = 1
    btn.Text = name
    btn.TextColor3 = Color3.fromRGB(140, 150, 160)
    btn.Font = Enum.Font.GothamBlack 
    btn.TextSize = 11
    btn.Parent = TabBar

    local page = Instance.new("Frame")
    page.Size = UDim2.new(1, 0, 1, 0)
    page.BackgroundTransparency = 1
    page.Visible = false
    page.Parent = Container

    tabs[name] = page
    tabButtons[name] = btn

    btn.MouseButton1Click:Connect(function()
        playClick()
        for k, v in pairs(tabs) do v.Visible = false end
        for k, v in pairs(tabButtons) do v.TextColor3 = Color3.fromRGB(140, 150, 160) end
        page.Visible = true
        btn.TextColor3 = Color3.fromRGB(0, 255, 255)
    end)

    return page
end

