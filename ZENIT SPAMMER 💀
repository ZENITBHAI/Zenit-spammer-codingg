local function findTargetPlayer(str)
    if str == "" or str == " " then return nil end
    for _, p in ipairs(Players:GetPlayers()) do
        if p.Name:lower():sub(1, #str) == str:lower() or p.DisplayName:lower():sub(1, #str) == str:lower() then
            return p
        end
    end
    return nil
end

local function sendChatMessage(message)
    if TextChatService.ChatVersion == Enum.ChatVersion.TextChatService then
        local generalChannel = TextChatService:FindFirstChild("RBXGeneral", true)
        if generalChannel and generalChannel:IsA("TextChannel") then
            generalChannel:SendAsync(message)
        end
    else
        game:GetService("ReplicatedStorage").DefaultChatSystemChatEvents.SayMessageRequest:FireServer(message, "All")
    end
end

local function startSpamEngine(modeSelected)
    if isSpamming then return end
    isSpamming = true
    activeSpamMode = modeSelected
    
    if activeSpamMode == "Custom" then
        InfoLabel.Text = "🎯 Custom Spam Isolated Active [50x Multiplier]"
    else
        local targetText = TargetInput.Text
        local targetPlayer = findTargetPlayer(targetText)
        local playerStringName = targetPlayer and targetPlayer.Name or (targetText ~= "" and targetText or "")
        if playerStringName ~= "" then
            InfoLabel.Text = "🎯 Target Locked: [" .. playerStringName .. "]"
        else
            InfoLabel.Text = "🎯 Global Spam Active [50x Multiplier]"
        end
    end

    coroutine.wrap(function()
        local spamIndex = 1
        while isSpamming do
            local finalMessage = ""
            local loopDelay = _G.ExtremeSpamSpeedMultiplier and 0.05 or baseDelay
            
            if activeSpamMode == "Custom" then
                local customMultiPattern = CustomPatternInput.Text
                local customTextContent = CustomContentInput.Text ~= "" and CustomContentInput.Text or "dominated by zenit"
                local multiBlock50 = customMultiPattern ~= "" and string.rep(customMultiPattern, 50) or string.rep("G_G", 50)
                
                finalMessage = multiBlock50 .. " " .. customTextContent
            else
                local targetText = TargetInput.Text
                local targetPlayer = findTargetPlayer(targetText)
                local playerStringName = targetPlayer and targetPlayer.Name or (targetText ~= "" and targetText or "")
                
                local standardMultiPattern = SpamPatternInput.Text
                local multiBlock50 = standardMultiPattern ~= "" and string.rep(standardMultiPattern, 50) or string.rep("Z/Z", 50)
                local rawSpamText = localSpams[spamIndex]
                
                if playerStringName ~= "" then
                    finalMessage = multiBlock50 .. " " .. playerStringName .. " " .. rawSpamText
                else
                    finalMessage = multiBlock50 .. " " .. rawSpamText
                end
                
                spamIndex = spamIndex + 1
                if spamIndex > #localSpams then spamIndex = 1 end
            end
            
            sendChatMessage(finalMessage)
            task.wait(loopDelay)
        end
    end)()
end

